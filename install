#!/usr/bin/env bash

set -Eeuo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$SCRIPT_DIR"

DIRECTORIES=(
  "$HOME/.config/kitty"
  "$HOME/.config/nvim"
  "$HOME/.zsh/plugins"
  "$HOME/workspace"
  "$HOME/code"
)

LINK_SPECS=(
  "git/gitconfig:$HOME/.gitconfig"
  "git/gitignore_global:$HOME/.gitignore_global"
  "tmux/tmux.conf:$HOME/.tmux.conf"
  "nvim/init.lua:$HOME/.config/nvim/init.lua"
  "kitty/kitty.conf:$HOME/.config/kitty/kitty.conf"
  "kitty/theme.conf:$HOME/.config/kitty/theme.conf"
  "zsh/zshrc:$HOME/.zshrc"
)

ensure_dir() {
  local dir=$1
  mkdir -p "$dir"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

ensure_source_exists() {
  local source=$1
  [[ -e "$source" ]] || die "source does not exist: $source"
}

link_matches_source() {
  local destination=$1
  local expected_source=$2

  [[ -L "$destination" ]] || return 1
  [[ "$(readlink "$destination")" == "$expected_source" ]]
}

link_file() {
  local source=$1
  local destination=$2

  ensure_source_exists "$source"

  if [[ ! -e "$destination" && ! -L "$destination" ]]; then
    ln -s "$source" "$destination"
    printf 'linked %s -> %s\n' "$destination" "$source"
    return
  fi

  if link_matches_source "$destination" "$source"; then
    printf 'ok %s\n' "$destination"
    return
  fi

  die "conflict at $destination (expected symlink to $source)"
}

main() {
  local dir
  for dir in "${DIRECTORIES[@]}"; do
    ensure_dir "$dir"
  done

  local spec relative_source destination source
  for spec in "${LINK_SPECS[@]}"; do
    relative_source=${spec%%:*}
    destination=${spec#*:}
    source="${REPO_ROOT}/${relative_source}"
    link_file "$source" "$destination"
  done
}

main "$@"
